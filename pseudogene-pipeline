#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_NAME="${ENV_NAME:-pseudogenePipeline}"
FASTA36_DIR="${FASTA36_DIR:-$HOME/fasta36}"
TEST25_DIR="$REPO_ROOT/test25"

log_progress() {
  local step="$1"
  local total="$2"
  local message="$3"
  printf '\n[%s/%s] %s\n' "$step" "$total" "$message"
}

usage() {
  cat <<EOF
Usage:
  bash pseudogene-pipeline install
  bash pseudogene-pipeline check
  bash pseudogene-pipeline test25
  bash pseudogene-pipeline configure-test25
  bash pseudogene-pipeline download-dfam <dest_dir>
  bash pseudogene-pipeline run <parameter_file>
  bash pseudogene-pipeline help

Environment variables:
  ENV_NAME     Conda environment name. Default: pseudogenePipeline
  FASTA36_DIR  Install/use fasta36 here. Default: \$HOME/fasta36
  SKIP_TEST25  If set to 1, skip test25 during install/test25. Default: 0
  RM_LIB       RepeatMasker library directory (overrides auto-detection)
  DFAM_LIB_DIR Alternative RepeatMasker library directory to use (sets RM_LIB)
  DFAM_DEST    Where to download Dfam if AUTO_DFAM=1 (defaults to /storage1/RepeatMasker/Libraries if writable, else $REPO_ROOT/dfam/Libraries)
  AUTO_DFAM    Auto-download Dfam (full) and use it. Default: 1

Examples:
  FASTA36_DIR=~/fasta36 bash pseudogene-pipeline install
  bash pseudogene-pipeline test25
  bash pseudogene-pipeline install
  bash pseudogene-pipeline download-dfam /path/to/RepeatMasker/Libraries
  bash pseudogene-pipeline run /path/to/parameter_file
EOF
}

need_conda() {
  if ! command -v conda >/dev/null 2>&1; then
    echo "ERROR: conda was not found in PATH." >&2
    exit 1
  fi
}

install_fasta36() {
  if [[ ! -d "$FASTA36_DIR/.git" ]]; then
    git clone https://github.com/wrpearson/fasta36.git "$FASTA36_DIR"
  fi

  pushd "$FASTA36_DIR/src" >/dev/null
  make -f ../make/Makefile.linux_sse2 all
  popd >/dev/null

  if [[ ! -x "$FASTA36_DIR/bin/tfasty36" ]]; then
    echo "ERROR: tfasty36 was not created at $FASTA36_DIR/bin/tfasty36" >&2
    exit 1
  fi
}

ensure_test25() {
  if [[ ! -d "$TEST25_DIR" ]]; then
    if [[ -f "$REPO_ROOT/test25.tgz" || -f "$REPO_ROOT/test25.tar.gz" ]]; then
      # Unpack bundled test data if present (gunzip then tar).
      if [[ -f "$REPO_ROOT/test25.tgz" ]]; then
        gunzip "$REPO_ROOT/test25.tgz"
      else
        gunzip "$REPO_ROOT/test25.tar.gz"
      fi
      tar -xf "$REPO_ROOT/test25.tar"
    else
      echo "ERROR: $TEST25_DIR is missing and $REPO_ROOT/test25.tgz not found." >&2
      echo "If you have the archive, run: gunzip test25.tgz (then extract test25.tar) or tar -xzf test25.tgz" >&2
      exit 1
    fi
  fi
}

repeatmasker_bin_dir() {
  dirname "$(command -v RepeatMasker)"
}

dfam_dest_dir() {
  if [[ -n "${DFAM_DEST:-}" ]]; then
    echo "$DFAM_DEST"
    return
  fi
  if [[ -d "/storage1" && -w "/storage1" ]]; then
    echo "/storage1/RepeatMasker/Libraries"
    return
  fi
  echo "$REPO_ROOT/dfam/Libraries"
}

has_dfam_full() {
  local dir="$1"
  ls "$dir"/dfam*_full.*.h5 >/dev/null 2>&1 && return 0
  ls "$dir"/dfam*_full.*.h5.gz >/dev/null 2>&1 && return 0
  return 1
}

ensure_dfam() {
  if [[ "${AUTO_DFAM:-1}" != "1" ]]; then
    return
  fi
  local dest
  dest="$(dfam_dest_dir)"
  mkdir -p "$dest"
  export DFAM_LIB_DIR="$dest"
  export RM_LIB="$dest"

  if ! has_dfam_full "$dest"; then
    echo "AUTO_DFAM=1: downloading Dfam full libraries to $dest"
    cmd_download_dfam "$dest"
  fi
}

ensure_repeatmasker_env() {
  ensure_dfam
  local rm_share
  rm_share="$(repeatmasker_bin_dir)/../share/RepeatMasker"
  if [[ -d "$rm_share" ]]; then
    if [[ -n "${DFAM_LIB_DIR:-}" ]]; then
      export RM_LIB="$DFAM_LIB_DIR"
    elif [[ -z "${RM_LIB:-}" ]]; then
      export RM_LIB="$rm_share/Libraries"
    fi
    export PATH="$PATH:$rm_share"
  fi
}

check_setup() {
  ensure_repeatmasker_env
  echo "Python: $(command -v python)"
  python -V
  echo "RepeatMasker: $(command -v RepeatMasker)"
  echo "rmblastn: $(command -v rmblastn)"
  echo "trf: $(command -v trf)"
  echo "tfasty36: $FASTA36_DIR/bin/tfasty36"

  test -x "$FASTA36_DIR/bin/tfasty36"
  test -x "$(command -v RepeatMasker)"
  test -x "$(command -v rmblastn)"
  test -x "$(command -v trf)"
  test -f "$REPO_ROOT/scripts/PseudogenePipeline.py"

  echo
  echo "Setup looks complete."
  echo "RepeatMasker bin dir: $(repeatmasker_bin_dir)"
}

can_run_repeatmasker() {
  if [[ "${SKIP_TEST25:-0}" == "1" ]]; then
    return 1
  fi

  if ! command -v RepeatMasker >/dev/null 2>&1; then
    return 1
  fi

  if command -v famdb.py >/dev/null 2>&1; then
    # test25 uses viridiplantae
    if ! famdb.py lineage viridiplantae >/dev/null 2>&1; then
      return 1
    fi
  fi

  return 0
}

configure_test25() {
  ensure_test25
  cat > "$TEST25_DIR/test_parameter_file" <<EOF
p_seq=test_prot25.fa
g_seq=test_genome.fa
#b_out=test_prot25_tblastn0
#b_format=pairwise
b_out=test_prot25_tblastn6
b_format=tabular
b_filter=y
ev_t=5
id_t=40
ml_t=30
ml_p=0.05
p_codes=../scripts
f_dir=$FASTA36_DIR/bin
f_prog=tfasty36
blosum=../example_files/blosum50.matrix
gff=test_gff
r_dir=$(repeatmasker_bin_dir)
r_species=viridiplantae
r_cut=300
r_div=30
il_t=456
overlap=0
################################################################################
# BLAST cmd: Note the BLAST+ executable location depends on your install
# makeblastdb -dbtype nucl -in test_genome.fa -input_type fasta -out test_genome
# tblastn -query test_prot25.fa -db test_genome -out test_prot25_tblastn0 -seg no -outfmt 0
# tblastn -query test_prot25.fa -db test_genome -out test_prot25_tblastn6 -seg no -outfmt 6
EOF

  echo "Wrote $TEST25_DIR/test_parameter_file"
}

run_test25() {
  ensure_repeatmasker_env
  if ! can_run_repeatmasker; then
    echo "WARNING: RepeatMasker/famdb not ready (or SKIP_TEST25=1). Skipping test25."
    echo "         Configure RM_LIB and verify: famdb.py lineage viridiplantae"
    return 0
  fi
  log_progress 1 3 "Writing test25 parameter file"
  configure_test25
  pushd "$TEST25_DIR" >/dev/null
  log_progress 2 3 "Running pseudogene pipeline on test25"
  python -u ../scripts/PseudogenePipeline.py test_parameter_file
  log_progress 3 3 "test25 completed"
  popd >/dev/null
}

activate_env() {
  need_conda
  local conda_base
  conda_base="$(conda info --base)"
  source "$conda_base/etc/profile.d/conda.sh"
  conda activate "$ENV_NAME"
}

install_env() {
  need_conda
  local conda_base
  conda_base="$(conda info --base)"
  source "$conda_base/etc/profile.d/conda.sh"

  if conda env list | awk '{print $1}' | grep -qx "$ENV_NAME"; then
    echo "Updating existing conda environment: $ENV_NAME"
    conda env update -n "$ENV_NAME" -f "$REPO_ROOT/environment.yml"
  else
    echo "Creating conda environment: $ENV_NAME"
    conda env create -n "$ENV_NAME" -f "$REPO_ROOT/environment.yml"
  fi

  conda activate "$ENV_NAME"
}

cmd_install() {
  install_env
  install_fasta36
  check_setup
  run_test25
  echo
  echo "Install completed successfully."
  echo "Use the tool with:"
  echo "  bash pseudogene-pipeline run <parameter_file>"
}

cmd_check() {
  log_progress 1 2 "Activating conda environment: $ENV_NAME"
  activate_env
  log_progress 2 2 "Checking dependency setup"
  check_setup
}

cmd_configure_test25() {
  log_progress 1 2 "Activating conda environment: $ENV_NAME"
  activate_env
  log_progress 2 2 "Configuring test25 parameter file"
  configure_test25
}

cmd_test25() {
  log_progress 1 2 "Activating conda environment: $ENV_NAME"
  activate_env
  log_progress 2 2 "Starting test25 run"
  run_test25
}

cmd_run() {
  if [[ $# -ne 1 ]]; then
    echo "ERROR: run requires exactly one parameter file." >&2
    usage
    exit 1
  fi

  local parameter_file="$1"
  log_progress 1 3 "Activating conda environment: $ENV_NAME"
  activate_env

  if [[ ! -f "$parameter_file" ]]; then
    echo "ERROR: parameter file not found: $parameter_file" >&2
    exit 1
  fi

  local run_dir
  run_dir="$(cd "$(dirname "$parameter_file")" && pwd)"
  local run_file
  run_file="$(basename "$parameter_file")"

  pushd "$run_dir" >/dev/null
  log_progress 2 3 "Running pipeline for $run_file"
  python -u "$REPO_ROOT/scripts/PseudogenePipeline.py" "$run_file"
  log_progress 3 3 "Pipeline run completed"
  popd >/dev/null
}

cmd_download_dfam() {
  if [[ $# -ne 1 ]]; then
    echo "ERROR: download-dfam requires a destination directory." >&2
    usage
    exit 1
  fi

  local dest_dir="$1"
  mkdir -p "$dest_dir"

  local base_url="https://www.dfam.org/releases/current/families/FamDB/"
  echo "Downloading Dfam FamDB (full) shards to: $dest_dir"
  echo "Source: $base_url"
  echo "Note: This is very large and may take hours; ensure you have space."

  if command -v wget >/dev/null 2>&1; then
    wget -c -r -np -nd -A "dfam*_full.*.h5.gz,dfam*_full.*.h5.gz.md5" \
      -P "$dest_dir" "$base_url"
  elif command -v curl >/dev/null 2>&1; then
    # curl doesn't support recursive listing; fetch index and download matches.
    curl -s "$base_url" \
      | sed -n 's/.*href="\\([^"]*dfam[^"]*full[^"]*\\.h5\\.gz\\(\\.md5\\)\\?\\)".*/\\1/p' \
      | sort -u \
      | while read -r f; do
          [[ -n "$f" ]] && curl -L -o "$dest_dir/$f" "$base_url/$f"
        done
  else
    echo "ERROR: neither wget nor curl found. Please install wget or download manually." >&2
    exit 1
  fi

  # Verify MD5 checksums if available
  if command -v md5sum >/dev/null 2>&1; then
    local md5_files
    md5_files=$(ls "$dest_dir"/*.md5 2>/dev/null || true)
    if [[ -n "$md5_files" ]]; then
      echo "Verifying MD5 checksums..."
      (cd "$dest_dir" && md5sum -c *.md5)
    fi
  else
    echo "WARNING: md5sum not found; skipping checksum verification."
  fi

  echo "Download complete. To use these, set DFAM_LIB_DIR to your RepeatMasker Libraries directory."
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    install)
      cmd_install "$@"
      ;;
    check)
      cmd_check "$@"
      ;;
    test25)
      cmd_test25 "$@"
      ;;
    download-dfam)
      cmd_download_dfam "$@"
      ;;
    configure-test25)
      cmd_configure_test25 "$@"
      ;;
    run)
      cmd_run "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "ERROR: unknown command: $command" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
